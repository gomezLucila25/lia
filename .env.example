# Copiá este archivo a .env y completá con tus claves.
# El .env está en .gitignore: nunca se commitea.

# --- OPCIÓN GRATIS (recomendada) ---
# Gemini tiene capa gratuita sin tarjeta. Sacá la key con tu cuenta de Google
# en https://aistudio.google.com/apikey
# Si esta variable está cargada, LIA usa Gemini automáticamente (gasto $0).
GEMINI_API_KEY=

# --- OPCIÓN PAGA (Claude) ---
# Solo si querés usar Claude. Se paga por uso (~centavos por análisis).
# ANTHROPIC_API_KEY=sk-ant-...

# Opcional: forzar un cerebro puntual -> LIA_IA=gemini  o  LIA_IA=claude
# LIA_IA=gemini
